# ============================================================
# ChillBot — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# Ollama model to use (must be pulled locally)
# Recommended: llama3.2:1b (fast) or mistral:7b (more capable)
# Run: ollama pull llama3.2:1b
OLLAMA_MODEL=llama3.2:1b

# Ollama server address (default: local)
OLLAMA_HOST=http://localhost:11434

# TMDB API key (optional — for live movie recommendations)
# Get a free key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Maximum ReAct reasoning iterations (default: 5)
MAX_ITERATIONS=5

# HTTP request timeout in seconds (default: 15)
TIMEOUT=120
